{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "outDir": "./out",
    "lib": ["ES2022"],
    "sourceMap": true,
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "Node16",
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "types": ["node", "vscode", "mocha"]
  },
  "exclude": [
    "media",
    "node_modules",
    "out",
    ".vscode-test",
    "src/test"
  ]
}
