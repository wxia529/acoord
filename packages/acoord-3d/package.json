{
  "name": "acoord-3d",
  "version": "0.1.0",
  "description": "Atomic structure 3D rendering engine powered by Three.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "author": "wxia529",
  "license": "MIT",
  "keywords": [
    "three.js",
    "crystal",
    "molecule",
    "structure",
    "visualization",
    "3d"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wxia529/acoord-3d"
  },
  "peerDependencies": {
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "three": "^0.183.2",
    "typescript": "^5.9.3",
    "esbuild": "^0.27.3",
    "@types/chai": "^5.0.1",
    "@types/mocha": "^10.0.10",
    "chai": "^5.1.2",
    "mocha": "^10.8.2",
    "tsx": "^4.21.0"
  },
  "scripts": {
    "build": "node build.config.mjs",
    "watch": "node build.config.mjs --watch",
    "test": "mocha --import tsx --timeout 5000 'test/**/*.test.ts'",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ]
